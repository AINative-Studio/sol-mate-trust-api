# ── Required — app will not start without these ───────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/solmate
SECRET_KEY=change-me-use-openssl-rand-hex-32

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="Sol Mate Trust API"
DEBUG=false
ENVIRONMENT=development

# ── Solana ────────────────────────────────────────────────────────────────────
# Wallet auth works without these. Needed for on-chain stake/escrow.
# Deploy program: cd solana && bash scripts/deploy_devnet.sh
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet
SOLANA_PROGRAM_ID=

# ── Circle USDC ───────────────────────────────────────────────────────────────
# Sign up (free sandbox): https://developer.circle.com
# Without this: stake flows work but USDC transfers are logged as stubs.
CIRCLE_API_KEY=
CIRCLE_ENVIRONMENT=sandbox
CIRCLE_ESCROW_WALLET_ID=
CIRCLE_SAFETY_FUND_WALLET_ID=

# ── Hedera HCS ────────────────────────────────────────────────────────────────
# Sign up (free testnet): https://portal.hedera.com
# Without this: attestations/safety actions are not anchored to HCS.
HEDERA_ACCOUNT_ID=
HEDERA_PRIVATE_KEY=
HEDERA_TOPIC_ID=
HEDERA_NETWORK=testnet

# ── ZeroDB (vector memory for AI matching) ───────────────────────────────────
# Get a free key: https://ainative.studio
# Without this: AI matching still works using built-in Postgres embeddings.
ZERODB_API_KEY=
ZERODB_PROJECT_ID=
ZERODB_API_URL=https://api.ainative.studio

# ── OpenAI (optional — enhances intro generation) ────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Stake thresholds (USDC) ───────────────────────────────────────────────────
MIN_STAKE_DM_USDC=0.5
MIN_STAKE_MEETUP_USDC=2.0
MIN_STAKE_ROOM_USDC=1.0
SLASH_AMOUNT_NO_SHOW=5.0

# ── Celery / Redis (background workers) ──────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

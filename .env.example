# App
APP_NAME="Sol Mate Trust API"
DEBUG=false
ENVIRONMENT=development

# Database (PgBouncer port 6432 in production)
DATABASE_URL=postgresql://solmate:solmate@localhost:5432/solmate

# Auth
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# Solana
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet

# Circle (USDC escrow)
CIRCLE_API_KEY=
CIRCLE_WALLET_SET_ID=

# Hedera (HCS anchoring + reputation)
HEDERA_ACCOUNT_ID=
HEDERA_PRIVATE_KEY=
HEDERA_NETWORK=testnet

# ZeroDB (vector memory)
ZERODB_API_URL=https://api.ainative.studio
ZERODB_PROJECT_ID=
ZERODB_USERNAME=
ZERODB_PASSWORD=

# AI
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Safety stake thresholds (USDC)
MIN_STAKE_DM_USDC=1.0
MIN_STAKE_MEETUP_USDC=5.0
MIN_STAKE_ROOM_USDC=0.5
SLASH_AMOUNT_NO_SHOW=5.0
